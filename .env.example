# =========================================================================
# OpenWebUI integration
# =========================================================================
CONTENT_EXTRACTION_ENGINE=external
EXTERNAL_DOCUMENT_EXTRACTOR_URL=http://doc-router:8000

# =========================================================================
# Upstream endpoints (internal, override only if running outside compose)
# =========================================================================
MINERU_ROUTER_URL=http://mineru-router:8002
PYMUPDF4LLM_URL=http://pymupdf4llm-api:8000
TIKA_URL=http://tika:9998

# =========================================================================
# MinerU
# =========================================================================
MINERU_MODEL_SOURCE=local

# =========================================================================
# Uploads
# =========================================================================
MAX_UPLOAD_MB=200
# Where the streamed body is written (per service container).
TMP_DIR=/tmp/doc-router

# =========================================================================
# PDF scan/text detection (in-process, doc-router only)
# =========================================================================
PDF_MIN_TEXT_CHARS=150
PDF_SCAN_SAMPLE_PAGES=3

# =========================================================================
# Per-process concurrency guards
# =========================================================================
MINERU_MAX_CONCURRENCY=2
PYMUPDF_MAX_CONCURRENCY=4
TIKA_MAX_CONCURRENCY=4

# =========================================================================
# Per-upstream timeouts (seconds)
# =========================================================================
PYMUPDF_TIMEOUT_SECONDS=300
TIKA_TIMEOUT_SECONDS=300
MINERU_TIMEOUT_SECONDS=1700
HEALTH_TIMEOUT_SECONDS=5

# =========================================================================
# Upstream retries (transient errors: 502/503/504 + httpx.TransportError)
# Set UPSTREAM_RETRIES=0 to disable.
# =========================================================================
UPSTREAM_RETRIES=1
UPSTREAM_RETRY_BACKOFF_SECONDS=0.5

# =========================================================================
# httpx client pool (shared, lifespan-managed)
# =========================================================================
HTTPX_MAX_KEEPALIVE=20
HTTPX_MAX_CONNECTIONS=50

# =========================================================================
# pymupdf4llm routing
# In-process by default. Set true to route via pymupdf4llm-api
# (also requires `docker compose --profile remote-pymupdf up`).
# =========================================================================
USE_REMOTE_PYMUPDF=false

# =========================================================================
# Logging
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT: text (human) | json (structured, one event per line)
# =========================================================================
LOG_LEVEL=INFO
LOG_FORMAT=text

# =========================================================================
# Security
# Optional shared secret. When set, /process, /health/ready and /health
# require: `Authorization: Bearer <value>`
# /health/live always stays open (used by the Docker healthcheck).
# =========================================================================
# EXTERNAL_API_KEY=
